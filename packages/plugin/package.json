{
  "name": "vitest-module-graph-reporter",
  "version": "1.0.0",
  "description": "Standalone Vitest reporter plugin that prints module graphs and enforces graph size thresholds.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.build.json && tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vitest",
    "vite",
    "reporter",
    "module-graph",
    "plugin"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tillkrischer/vitest-module-graph-reporter.git"
  },
  "homepage": "https://github.com/tillkrischer/vitest-module-graph-reporter#readme",
  "bugs": {
    "url": "https://github.com/tillkrischer/vitest-module-graph-reporter/issues"
  },
  "peerDependencies": {
    "vite": "^6.4.1 || ^7.0.0",
    "vitest": "^3.2.4"
  }
}
