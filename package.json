{
  "name": "vitest-module-graph-reporter-workspace",
  "private": true,
  "workspaces": [
    "packages/plugin",
    "packages/test-harness"
  ],
  "scripts": {
    "build": "npm run build --workspace vitest-module-graph-reporter",
    "check": "npm run check --workspace vitest-module-graph-reporter && npm run check --workspace vitest-module-graph-reporter-test-harness",
    "test": "npm run test --workspace vitest-module-graph-reporter-test-harness"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
